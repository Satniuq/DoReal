{
  "schema_version": "1.0",
  "publish_only_if_validated": true,
  "overwrite_policy": "never_overwrite_without_backup",
  "versioning_policy": "preserve_existing_and_append_run_metadata",
  "merge_after_publish": true,
  "reindex_after_publish": true,
  "allow_delete": false,
  "staging_required": true,
  "publication_order": [
    "copy_to_staging",
    "validate_again",
    "publish_to_canonical_folder",
    "rebuild_local_merge",
    "rebuild_global_merge",
    "rebuild_transition_merge_if_applicable",
    "reindex"
  ]
}