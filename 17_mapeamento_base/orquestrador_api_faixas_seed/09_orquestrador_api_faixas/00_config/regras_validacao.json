{
  "schema_version": "1.0",
  "filename_patterns": {
    "abertura_faixa": "^ABERTURA_FAIXA_EXPOSITIVA_CONTROLADA_[A-Z0-9_]+\\.md$",
    "ensaio_controlado": "^ENSAIO_CONTROLADO_[A-Z0-9_]+_v\\d+\\.md$",
    "decisao_limite": "^(DECISAO_CONTROLADA_[A-Z0-9_]+|NOTA_LIMITE_[A-Z0-9_]+)\\.md$",
    "consolidacao_faixa": "^CONSOLIDACAO_FAIXA_[A-Z0-9_]+\\.md$",
    "transicao_faixa": "^\\d{2}_para_\\d{2}_DECISAO_SOBRE_PROXIMA_FAIXA(_EXPOSITIVA_CONTROLADA|_E_CADENCIA_DE_TRATAMENTO)?\\.md$"
  },
  "required_frontmatter_fields": [
    "artifact_type",
    "faixa_id",
    "status",
    "generated_at",
    "run_id",
    "prompt_id"
  ],
  "required_sections_by_artifact_type": {
    "abertura_faixa": [
      "I. Estatuto da abertura",
      "II. Solo real mínimo",
      "III. Centro próprio",
      "IV. Ordem mínima",
      "V. Falsos centros a bloquear",
      "VI. Fronteiras negativas",
      "VII. Travões obrigatórios"
    ],
    "ensaio_controlado": [
      "I. Estatuto do ensaio",
      "II. Sequência testada",
      "III. Onde o texto aguenta",
      "IV. Onde o texto deixa de aguentar",
      "V. Veredito local"
    ],
    "decisao_limite": [
      "I. Estatuto da decisão",
      "II. Ganho preservado",
      "III. Limite máximo atual",
      "IV. O que fica fora",
      "V. Próximo passo prudente"
    ],
    "consolidacao_faixa": [
      "I. Estatuto da consolidação",
      "II. Faixa já consolidada",
      "III. Ordem local mínima já ganha",
      "IV. Limite preservado"
    ],
    "transicao_faixa": [
      "I. Estatuto da decisão",
      "II. Estado da faixa atual",
      "III. Candidatas a próxima faixa",
      "IV. Decisão final"
    ]
  },
  "state_to_expected_artifacts": {
    "TRANSICAO_DECIDIDA": [
      "abertura_faixa"
    ],
    "ABERTA_PUBLICADA": [
      "ensaio_controlado",
      "decisao_limite"
    ],
    "ENSAIO_GERADO": [
      "decisao_limite"
    ],
    "LIMITE_FIXADO": [
      "consolidacao_faixa",
      "transicao_faixa"
    ],
    "CONSOLIDADA": [
      "transicao_faixa"
    ],
    "NEGATIVA_FECHADA": [
      "transicao_faixa"
    ]
  },
  "automatic_rejection_rules": [
    "rejeitar_v2_sem_decisao_intermedia",
    "rejeitar_consolidacao_sem_limite",
    "rejeitar_reabertura_de_faixa_consolidada_sem_decisao_expressa",
    "rejeitar_publicacao_de_artefacto_diferente_do_esperado"
  ]
}