  "regras_de_validacao": {
    "regras_gerais": [
      {
        "id": "RG01",
        "descricao": "Todo o documento deve conter metadata, fontes, estatisticas, enums_documentados e regras_de_validacao."
      },
      {
        "id": "RG02",
        "descricao": "Todo o enum referido em schema_unidade_de_confronto e schema_lista_auxiliar deve estar documentado em enums_documentados."
      },
      {
        "id": "RG03",
        "descricao": "Os campos obrigatórios de schema_unidade_de_confronto devem estar explicitados e ter tipo definido."
      },
      {
        "id": "RG04",
        "descricao": "Os campos obrigatórios de schema_lista_auxiliar devem estar explicitados e ter tipo definido."
      },
      {
        "id": "RG05",
        "descricao": "Os enums reutilizados do projeto devem manter compatibilidade semântica com os já usados em mapa_campos_do_real_v1.json."
      },
      {
        "id": "RG06",
        "descricao": "O schema deve distinguir claramente problema filosófico, subproblema e problema metaestrutural."
      },
      {
        "id": "RG07",
        "descricao": "O schema deve permitir ligar problemas a proposições, campos, pontes e ancoragens sem obrigar a preenchimento exaustivo nesta fase preliminar."
      },
      {
        "id": "RG08",
        "descricao": "Se necessita_revisao_humana=true, motivo_revisao_humana deve estar preenchido."
      },
      {
        "id": "RG09",
        "descricao": "Se exige_resposta_canonica=true, tipo_de_resposta_exigida não pode estar vazio."
      },
      {
        "id": "RG10",
        "descricao": "Se grau_de_cobertura_no_projeto=ausente, o problema não deve ser marcado como estruturante sem justificação metodológica."
      },
      {
        "id": "RG11",
        "descricao": "Campos *_ids_relacionadas devem usar identificadores existentes ou reservados de forma coerente com o projeto."
      },
      {
        "id": "RG12",
        "descricao": "A lista auxiliar não substitui a matriz de confronto filosófico; serve para reconhecimento e normalização prévia."
      }
    ]
  },
