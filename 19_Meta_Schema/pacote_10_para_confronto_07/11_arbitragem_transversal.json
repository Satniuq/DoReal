      "decisao": "prevalece_estrutural_canonica",
      "justificacao": "Apesar da forte compatibilidade estrutural dos três argumentos com a função dominante, a heterogeneidade excessiva e a presença de mais de dois argumentos impedem a manutenção restritiva de qualquer argumento isolado ou dupla excepcional.",
      "necessita_revisao_humana": false,
      "fonte": {
        "fonte_id": "SRC_ADJUDICACAO_ARGUMENTOS"
      }
    },
    {
      "id": "ARB_R_RA_0011",
      "alvo": {
        "tipo_entidade": "ramo",
        "id": "RA_0011"
      },
