      ],
      "tipo_de_conflito": "divergencia_estrutural",
      "regra_de_prevalencia_aplicada": "RP_005",
      "decisao": "prevalece_estrutural_canonica",
      "justificacao": "Mantém-se um único argumento operacional meta-dedutivo alinhado com a função dominante do ramo, evitando heterogeneidade excessiva e incompatibilidades estruturais.",
