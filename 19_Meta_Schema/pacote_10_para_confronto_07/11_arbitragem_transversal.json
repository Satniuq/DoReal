      ],
      "tipo_de_conflito": "divergencia_estrutural",
      "regra_de_prevalencia_aplicada": "RP_005",
      "decisao": "prevalece_estrutural_canonica",
      "justificacao": "Dois argumentos epistemológicos meta-dedutivos são estruturalmente compatíveis e expressam claramente a função dominante do ramo, justificando exceção para manter ambos; o terceiro argumento é incompatível e excluído.",
      "necessita_revisao_humana": false,
      "fonte": {
        "fonte_id": "SRC_ADJUDICACAO_ARGUMENTOS"
      }
    },
    {
      "id": "ARB_R_RA_0008",
      "alvo": {
        "tipo_entidade": "ramo",
        "id": "RA_0008"
      },
      "camadas_em_tensao": [
