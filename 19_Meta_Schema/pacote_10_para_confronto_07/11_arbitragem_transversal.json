    },
    {
      "id": "ARB_R_RA_0005",
      "alvo": {
        "tipo_entidade": "ramo",
        "id": "RA_0005"
      },
      "camadas_em_tensao": [
        "estrutural_canonica",
        "arbitragem_transversal"
      ],
      "tipo_de_conflito": "divergencia_estrutural",
      "regra_de_prevalencia_aplicada": "RP_005",
      "decisao": "prevalece_estrutural_canonica",
      "justificacao": "Apesar da forte compatibilidade estrutural e alta confiança individual, a presença de três argumentos igualmente fortes e compatíveis gera heterogeneidade excessiva e impede a seleção restritiva de um ou dois argumentos. A prudência recomenda manter_0 para evitar inflacão argumentativa e garantir revisão futura.",
      "necessita_revisao_humana": false,
      "fonte": {
        "fonte_id": "SRC_ADJUDICACAO_ARGUMENTOS"
      }
    },
    {
      "id": "ARB_R_RA_0007",
      "alvo": {
        "tipo_entidade": "ramo",
